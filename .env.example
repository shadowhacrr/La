# Bot Configuration
BOT_TOKEN=your_bot_token_here_from_botfather
OWNER_ID=your_telegram_user_id_here

# Verification Channels
TELEGRAM_CHANNEL=@your_telegram_channel_username
YOUTUBE_CHANNEL=https://youtube.com/@yourchannel
